<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>EcoScore — Doğa Puanı</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#0d1f0f;--moss:#3d6b47;--fern:#5a9a68;--lime:#8dc98a;
  --amber:#e8a02a;--coral:#e05c3a;--cream:#faf8f2;--gold:#c9992a;
  --r:12px;--r2:18px;
}
html,body{height:100%;font-family:'DM Sans',sans-serif;background:#1a2a1a;display:flex;align-items:center;justify-content:center}
.phone-frame{
  width:390px;height:844px;
  background:var(--cream);
  border-radius:44px;
  overflow:hidden;
  box-shadow:0 40px 80px rgba(0,0,0,.6),0 0 0 10px #111,0 0 0 12px #333;
  display:flex;flex-direction:column;
  position:relative;
}
/* Notch */
.notch{position:absolute;top:0;left:50%;transform:translateX(-50%);width:120px;height:34px;background:#111;border-radius:0 0 20px 20px;z-index:100}
.shell{display:flex;height:100%;overflow:hidden;padding-top:34px}
.sidebar{width:64px;background:#0d1f0f;display:flex;flex-direction:column;align-items:center;padding:14px 0;gap:5px;flex-shrink:0}
.logo-mark{width:34px;height:34px;background:var(--fern);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;margin-bottom:10px}
.sib-wrap{display:flex;flex-direction:column;align-items:center;width:100%}
.sib{width:38px;height:38px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;cursor:pointer;border:none;background:none;color:white}
.sib.active{background:var(--moss)}
.sib-label{font-size:9px;color:#6a8a6a;margin-top:1px;text-align:center;line-height:1.2;width:100%}
.main{flex:1;overflow:hidden}
.page{display:none;height:100%;overflow-y:auto;animation:fin .3s ease}
.page.active{display:block}
.page::-webkit-scrollbar{width:3px}
.page::-webkit-scrollbar-thumb{background:rgba(90,154,104,.3);border-radius:3px}
@keyframes fin{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes pop{0%,100%{transform:scale(1)}50%{transform:scale(1.06)}}
@keyframes shake{0%,100%{transform:translateX(0)}30%{transform:translateX(-6px)}70%{transform:translateX(6px)}}

/* HOME */
.home-top{background:linear-gradient(155deg,#1a3320,#1e4a50);padding:26px 22px 18px;position:relative;overflow:hidden}
.home-top::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 65% 40%,rgba(141,201,138,.1),transparent 60%)}
.eco-brand{display:flex;align-items:center;gap:9px;margin-bottom:16px}
.eco-logo{font-family:'DM Serif Display',serif;font-size:25px;color:white}
.eco-logo span{color:var(--lime)}
.eco-badge{background:rgba(141,201,138,.2);border:1px solid rgba(141,201,138,.4);border-radius:20px;padding:3px 9px;font-size:11px;color:var(--lime);font-weight:500}
.dp-row{display:flex;align-items:flex-end;gap:10px;margin-bottom:5px}
.dp-num{font-family:'DM Serif Display',serif;font-size:48px;color:white;line-height:1}
.dp-unit{font-size:12px;color:var(--lime);font-weight:600;margin-bottom:3px}
.dp-sub{font-size:11px;color:rgba(255,255,255,.45)}
.level-row{display:flex;align-items:center;gap:9px;margin-top:9px}
.level-pill{background:var(--amber);color:#0d1f0f;border-radius:20px;padding:4px 11px;font-size:12px;font-weight:600}
.lvl-bar{flex:1;height:5px;background:rgba(255,255,255,.12);border-radius:10px;overflow:hidden}
.lvl-fill{height:100%;background:linear-gradient(90deg,var(--lime),var(--amber));width:67%;border-radius:10px}
.lvl-pct{font-size:11px;color:rgba(255,255,255,.45)}
.home-body{padding:16px 20px}
.sec{font-size:10px;font-weight:600;color:#4a6a4a;text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px}
.impact-row{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:20px}
.imp-card{background:white;border-radius:var(--r);padding:12px 8px;text-align:center;border:.5px solid rgba(90,154,104,.15)}
.imp-icon{font-size:20px;margin-bottom:4px}
.imp-val{font-size:17px;font-weight:600;color:var(--moss)}
.imp-lbl{font-size:9px;color:#7a8a7a;margin-top:1px}
.milestone-box{background:linear-gradient(135deg,#1a3320,#1e4a50);border-radius:var(--r2);padding:14px 16px;margin-bottom:18px;position:relative;overflow:hidden}
.milestone-box::after{content:'🌳';position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:36px;opacity:.18}
.ml-label{font-size:10px;color:var(--lime);font-weight:600;margin-bottom:3px}
.ml-title{font-size:14px;font-weight:600;color:white;margin-bottom:8px}
.ml-bar{height:6px;background:rgba(255,255,255,.1);border-radius:10px;overflow:hidden;margin-bottom:4px}
.ml-fill{height:100%;background:linear-gradient(90deg,var(--lime),var(--amber));border-radius:10px}
.ml-sub{font-size:11px;color:rgba(255,255,255,.4)}
.daily-card{background:white;border-radius:var(--r2);padding:14px 16px;display:flex;align-items:center;gap:12px;border:.5px solid rgba(232,160,42,.3);margin-bottom:18px}
.daily-info{flex:1}
.daily-tag{font-size:10px;font-weight:700;color:var(--amber);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px}
.daily-title{font-size:14px;font-weight:600;color:var(--ink);margin-bottom:1px}
.daily-sub{font-size:11px;color:#7a8a7a}
.daily-play{background:#1a3320;color:white;border:none;border-radius:9px;padding:9px 13px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap}
.cat-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px}
.cat-btn{border-radius:var(--r2);padding:15px 13px;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;text-align:left}
.cat-btn .cb-icon{font-size:22px;margin-bottom:6px;display:block}
.cat-btn .cb-name{font-size:13px;font-weight:700;display:block;margin-bottom:1px}
.cat-btn .cb-count{font-size:11px;opacity:.6}
.cb-birds{background:#dbeafe;color:#1e3a8a}
.cb-mammals{background:#fef3c7;color:#78350f}
.cb-flora{background:#dcfce7;color:#14532d}
.cb-ecology{background:#ede9fe;color:#4c1d95}

/* KATEGORİ SEÇİM */
.cat-header{background:linear-gradient(155deg,#1a3320,#1e4a50);padding:22px 22px 18px;text-align:center}
.cat-header-title{font-family:'DM Serif Display',serif;font-size:22px;color:white;margin-bottom:3px}
.cat-header-sub{font-size:12px;color:rgba(255,255,255,.45)}
.cat-body{padding:16px 18px}
.diff-box{background:white;border-radius:var(--r2);padding:16px;border:.5px solid rgba(90,154,104,.2);margin-bottom:14px}
.diff-box-title{font-size:13px;font-weight:700;color:var(--ink);margin-bottom:12px;display:flex;align-items:center;gap:7px}
.diff-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.diff-btn{padding:13px 6px;border-radius:var(--r);cursor:pointer;font-family:'DM Sans',sans-serif;text-align:center;border:2px solid transparent}
.diff-btn.easy{background:#f0fdf4;border-color:#22c55e;color:#15803d}
.diff-btn.medium{background:#fffbeb;border-color:#f59e0b;color:#b45309}
.diff-btn.hard{background:#fff1f0;border-color:#ef4444;color:#b91c1c}
.diff-icon{font-size:20px;margin-bottom:4px}
.diff-name{font-size:12px;font-weight:700;display:block;margin-bottom:1px}
.diff-pts{font-size:11px;opacity:.7}

/* QUIZ */
.quiz-top{background:linear-gradient(155deg,#1a3320,#1e4a50);padding:16px 20px 20px}
.quiz-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:13px}
.quiz-pills{display:flex;gap:6px;align-items:center}
.cat-pill{background:rgba(141,201,138,.2);border:1px solid rgba(141,201,138,.3);border-radius:20px;padding:3px 10px;font-size:11px;color:var(--lime);font-weight:500}
.d-pill{border-radius:20px;padding:3px 9px;font-size:11px;font-weight:700}
.d-pill.easy{background:rgba(34,197,94,.2);color:#86efac}
.d-pill.medium{background:rgba(245,158,11,.2);color:#fcd34d}
.d-pill.hard{background:rgba(239,68,68,.2);color:#fca5a5}
.timer-wrap{position:relative;width:44px;height:44px}
.timer-wrap svg{transform:rotate(-90deg)}
.timer-wrap circle{fill:none;stroke-width:3}
.t-bg{stroke:rgba(255,255,255,.1)}
.t-fill{stroke:var(--lime);stroke-linecap:round;stroke-dasharray:120;transition:stroke-dashoffset .9s linear}
.t-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:white}
.q-dots{display:flex;gap:4px;margin-bottom:12px}
.q-dot{flex:1;height:4px;border-radius:3px;background:rgba(255,255,255,.12)}
.q-dot.done{background:var(--lime)}
.q-dot.cur{background:var(--amber)}
.score-live{text-align:center}
.score-big{font-family:'DM Serif Display',serif;font-size:30px;color:white}
.score-sub{font-size:10px;color:rgba(255,255,255,.4);margin-top:1px}
.quiz-card{background:white;margin:0 16px;margin-top:-12px;border-radius:var(--r2);overflow:hidden;box-shadow:0 6px 24px rgba(0,0,0,.08)}
.q-img{width:100%;height:145px;object-fit:cover;display:block}
.q-img-ph{width:100%;height:145px;display:flex;align-items:center;justify-content:center;font-size:50px;background:linear-gradient(135deg,#dbeafe,#dcfce7)}
.q-body{padding:14px 16px 12px}
.q-badge{display:inline-block;background:#f0fdf4;color:var(--moss);border-radius:20px;padding:3px 9px;font-size:11px;font-weight:600;margin-bottom:9px}
.streak-bar{background:#fef3c7;border-radius:8px;padding:6px 10px;font-size:12px;color:#78350f;font-weight:600;margin-bottom:8px;display:none;align-items:center;gap:5px}
.q-text{font-size:15px;font-weight:600;color:var(--ink);line-height:1.4}
.opts{display:grid;gap:7px;padding:8px 16px 14px}
.opt{display:flex;align-items:center;gap:10px;background:#f4f7f4;border:1.5px solid #c8dcc8;border-radius:var(--r);padding:12px 13px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;color:var(--ink);text-align:left;width:100%}
.opt-ltr{width:26px;height:26px;border-radius:50%;background:#e0ece0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;color:var(--moss)}
.opt.correct{background:#166534;border-color:#166534;color:white;animation:pop .3s ease}
.opt.correct .opt-ltr{background:rgba(255,255,255,.25);color:white}
.opt.wrong{background:#991b1b;border-color:#991b1b;color:white;animation:shake .3s ease}
.opt.wrong .opt-ltr{background:rgba(255,255,255,.2);color:white}
.opt:disabled{cursor:default}
.dp-award{background:linear-gradient(135deg,#1a3320,#1e4a50);border-radius:var(--r);padding:11px 14px;margin:0 16px;display:none;align-items:center;gap:11px}
.dp-award.show{display:flex;animation:fin .3s ease}
.award-pts{font-family:'DM Serif Display',serif;font-size:24px;color:var(--lime)}
.award-txt{font-size:12px;color:rgba(255,255,255,.7);line-height:1.4}
.award-form{font-size:11px;color:var(--lime);margin-top:2px}
.next-btn{width:calc(100% - 32px);margin:9px 16px 16px;background:var(--moss);color:white;border:none;border-radius:var(--r);padding:12px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;display:none}
.next-btn.show{display:block;animation:fin .3s ease}

/* ETKİ */
.impact-top{background:linear-gradient(155deg,#1e4a50,#0d1f0f);padding:24px 22px;text-align:center}
.impact-title{font-family:'DM Serif Display',serif;font-size:24px;color:white;margin-bottom:4px}
.impact-sub{font-size:12px;color:rgba(255,255,255,.45)}
.global-grid{background:rgba(255,255,255,.05);border:1px solid rgba(141,201,138,.2);border-radius:var(--r2);padding:13px;margin-top:13px;display:grid;grid-template-columns:repeat(3,1fr);gap:9px;text-align:center}
.gp-val{font-family:'DM Serif Display',serif;font-size:20px;color:var(--lime)}
.gp-lbl{font-size:10px;color:rgba(255,255,255,.38);margin-top:1px}
.impact-body{padding:16px 20px}
.threshold-list{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.th{background:white;border-radius:var(--r2);padding:14px 16px;border:.5px solid rgba(90,154,104,.15);display:flex;align-items:center;gap:12px}
.th.done{border-color:var(--fern);background:#f0fdf4}
.th.next{border:2px solid var(--amber);background:#fffbeb}
.th-icon{font-size:26px;flex-shrink:0}
.th-body{flex:1}
.th-title{font-size:14px;font-weight:700;color:var(--ink);margin-bottom:1px}
.th-desc{font-size:11px;color:#7a8a7a;margin-bottom:5px;line-height:1.4}
.th-pts{font-size:11px;color:#7a8a7a}
.th-bar{height:4px;background:rgba(0,0,0,.06);border-radius:10px;overflow:hidden;margin-top:6px}
.th-fill{height:100%;border-radius:10px}
.th-stat{font-size:12px;font-weight:600;flex-shrink:0;min-width:30px;text-align:right}
.th.done .th-stat{color:var(--moss)}
.th.next .th-stat{color:var(--amber)}
.log-box{background:white;border-radius:var(--r2);padding:14px 16px;border:.5px solid rgba(90,154,104,.15)}
.log-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:.5px solid rgba(90,154,104,.08)}
.log-row:last-child{border-bottom:none}
.log-ic{font-size:17px}
.log-info{flex:1}
.log-t{font-size:13px;font-weight:600;color:var(--ink)}
.log-d{font-size:11px;color:#7a8a7a;margin-top:1px}
.log-pts{font-size:12px;font-weight:700;color:var(--fern)}

/* LİDERLİK */
.lb-top{background:linear-gradient(155deg,#2d1a40,#1a2d40);padding:20px 22px 24px;text-align:center}
.lb-title{font-family:'DM Serif Display',serif;font-size:23px;color:white;margin-bottom:3px}
.lb-tabs{display:flex;background:rgba(255,255,255,.08);border-radius:20px;padding:3px;margin-top:11px}
.lb-tab{flex:1;padding:6px;border-radius:15px;font-size:12px;font-weight:600;color:rgba(255,255,255,.5);border:none;background:none;cursor:pointer;font-family:'DM Sans',sans-serif}
.lb-tab.active{background:white;color:var(--ink)}
.lb-podium{display:flex;align-items:flex-end;justify-content:center;gap:7px;padding:16px 20px;background:white;border-bottom:.5px solid rgba(0,0,0,.05)}
.pod{display:flex;flex-direction:column;align-items:center;gap:4px}
.pod-av{border-radius:50%;display:flex;align-items:center;justify-content:center;border:3px solid transparent}
.pod.first .pod-av{width:52px;height:52px;font-size:22px;border-color:var(--gold)}
.pod.second .pod-av,.pod.third .pod-av{width:42px;height:42px;font-size:18px}
.pod.second .pod-av{border-color:#9ca3af}
.pod.third .pod-av{border-color:#c97c3a}
.pod-name{font-size:10px;font-weight:600;color:#2a3d2c}
.pod-pts{font-size:12px;font-weight:700;color:var(--moss)}
.pod-blk{border-radius:6px 6px 0 0;width:52px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:white}
.pod.first .pod-blk{height:40px;background:var(--gold)}
.pod.second .pod-blk{height:27px;background:#9ca3af}
.pod.third .pod-blk{height:19px;background:#c97c3a}
.lb-list{padding:0 20px 16px}
.lb-row{display:flex;align-items:center;gap:10px;padding:11px 0;border-bottom:.5px solid rgba(0,0,0,.05)}
.lb-row.me{background:#f0fdf4;border-radius:var(--r);padding:11px 10px;margin:0 -10px;border-bottom:none}
.lb-n{font-size:13px;font-weight:700;width:20px;color:#aaa;text-align:center}
.lb-av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.lb-det{flex:1}
.lb-name{font-size:13px;font-weight:600;color:var(--ink)}
.lb-bdg{font-size:11px;color:#7a8a7a;margin-top:1px}
.lb-sc{font-size:14px;font-weight:700;color:var(--moss)}
.you-tag{font-size:9px;background:var(--lime);color:white;border-radius:20px;padding:1px 5px;margin-left:3px;vertical-align:middle}

/* PROFİL */
.prof-top{background:linear-gradient(155deg,#1a3320,#2d5a3a);padding:24px 22px;text-align:center}
.prof-av{width:64px;height:64px;border-radius:50%;background:rgba(141,201,138,.2);border:3px solid var(--lime);display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 9px}
.prof-name{font-family:'DM Serif Display',serif;font-size:20px;color:white}
.prof-lv{font-size:12px;color:var(--lime);margin-top:2px}
.prof-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:12px}
.ps{background:rgba(255,255,255,.07);border-radius:var(--r);padding:8px 6px;text-align:center}
.ps-v{font-size:16px;font-weight:700;color:white}
.ps-l{font-size:9px;color:rgba(255,255,255,.38);margin-top:1px}
.cert-sec{padding:16px 20px}
.cert-card{background:white;border-radius:var(--r2);padding:20px;border:.5px solid rgba(90,154,104,.2);text-align:center;margin-bottom:13px;position:relative;overflow:hidden}
.cert-card::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='36' height='36' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='18' cy='18' r='1' fill='%235a9a68' opacity='.06'/%3E%3C/svg%3E");background-size:36px 36px}
.cert-top-row{display:flex;align-items:center;justify-content:center;gap:7px;margin-bottom:11px}
.cert-logo-txt{font-family:'DM Serif Display',serif;font-size:14px;color:var(--moss)}
.cert-div{height:1px;background:linear-gradient(90deg,transparent,rgba(90,154,104,.3),transparent);margin-bottom:13px}
.cert-seal{font-size:36px;margin-bottom:6px}
.cert-title{font-family:'DM Serif Display',serif;font-size:24px;color:var(--ink);margin-bottom:3px}
.cert-sub{font-size:12px;color:#7a8a7a;margin-bottom:9px}
.cert-name{font-family:'DM Serif Display',serif;font-size:19px;color:var(--moss);margin-bottom:7px}
.cert-body{font-size:12px;color:#2a3d2c;line-height:1.6;margin-bottom:12px}
.cert-date{font-size:10px;color:#7a8a7a}
.cert-acts{display:flex;gap:7px;margin-top:11px}
.ca{flex:1;padding:9px;border-radius:var(--r);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;border:none}
.ca-dl{background:var(--moss);color:white}
.ca-sh{background:#f0fdf4;color:var(--moss);border:1.5px solid var(--fern)}
.bdg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px}
.bdg{background:white;border-radius:var(--r);padding:12px 8px;text-align:center;border:.5px solid rgba(90,154,104,.15)}
.bdg.locked{opacity:.4;filter:grayscale(1)}
.bdg-i{font-size:22px;margin-bottom:5px}
.bdg-n{font-size:11px;font-weight:700;color:var(--ink);line-height:1.3}
.bdg-r{font-size:10px;color:#7a8a7a;margin-top:1px}

/* MAĞAZA */
.store-top{background:linear-gradient(155deg,#2d1a0d,#4a2f1a);padding:20px 22px 16px}
.store-title{font-family:'DM Serif Display',serif;font-size:21px;color:white;margin-bottom:2px}
.store-sub{font-size:12px;color:rgba(255,255,255,.45)}
.store-body{padding:16px 20px}
.prod-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.prod{background:white;border-radius:var(--r2);overflow:hidden;border:.5px solid rgba(0,0,0,.06)}
.prod-img{height:100px;display:flex;align-items:center;justify-content:center;font-size:40px;position:relative}
.prod-badge{position:absolute;top:6px;left:6px;border-radius:20px;padding:2px 7px;font-size:10px;font-weight:700}
.dig{background:#ede9fe;color:#4c1d95}
.phys{background:#fef3c7;color:#78350f}
.prod-body{padding:10px}
.prod-name{font-size:12px;font-weight:600;color:var(--ink);margin-bottom:3px}
.prod-price{display:flex;align-items:center;justify-content:space-between}
.price-main{font-size:13px;font-weight:700;color:var(--ink)}
.price-dp{font-size:10px;color:var(--fern);font-weight:600}
