elah kaç yaşındadır?',opts:['~1.000','~2.500','~4.800','~10.000'],ans:2,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/turkey_forest/480/160',q:"Türkiye'nin orman örtüsü yüzde kaçtır?",opts:['%10','%16','%28','%42'],ans:2,type:'🇹🇷 Uzman'}]},Ekoloji:{kolay:[{img:'https://picsum.photos/seed/food_chain/480/160',q:'Gıda zincirinde enerji hangi yönde akar?',opts:['Üreticiden tüketiciye','Tüketiciden üreticiye','Her iki yönde','Döngüsel'],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/biodiversity/480/160',q:'Biyoçeşitlilik ne demektir?',opts:['Farklı türlerin zenginliği','Bir türün çokluğu','Bitki sayısı','Deniz derinliği'],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/climate1/480/160',q:'İklim değişikliğinin en temel göstergesi nedir?',opts:['Küresel sıcaklık artışı','Nüfus artışı','Orman yangınları','Şehirleşme'],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/wetland1/480/160',q:'Sulak alanların ekosistemdeki temel işlevi nedir?',opts:['Su arıtma ve biyoçeşitlilik','Tarım alanı','Şehir parkı','Sanayi bölgesi'],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/decomp1/480/160',q:'Besin döngüsünde ayrıştırıcı görevi kimler üstlenir?',opts:['Bakteri ve mantarlar','Bitkiler','Yırtıcılar','Otçullar'],ans:0,type:'🧠 Bilgi'}],orta:[{img:'https://picsum.photos/seed/ramsar1/480/160',q:"Türkiye'de kaç Ramsar sulak alan statüsünde bölge vardır?",opts:['5','14','30','50'],ans:1,type:'🇹🇷 Türkiye'},{img:'https://picsum.photos/seed/keystone/480/160',q:'Kilit taş (keystone) tür ne demektir?',opts:['En çok sayıda tür','Ekosistemin dengesini koruyan tür','En büyük tür','Tehlikeli tür'],ans:1,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/habitat/480/160',q:'Habitat tahribatının başlıca nedeni nedir?',opts:['Tarım arazisine dönüşüm','Doğal afet','İklim değişikliği','Su baskını'],ans:0,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/taurus_eco/480/160',q:'Toros Dağları ekolojik açıdan neden kritiktir?',opts:['Tatlı su kaynakları ve endemizm','Turizm geliri','Tarım alanları','Maden rezervleri'],ans:0,type:'🇹🇷 Türkiye'},{img:'https://picsum.photos/seed/carbon1/480/160',q:'Karbon döngüsünde ormanlar hangi rolü oynar?',opts:['Karbon depolayıcı','Karbon salan','Nötr','İkisi de'],ans:0,type:'🔬 Bilim'}],zor:[{img:'https://picsum.photos/seed/koycegiz/480/160',q:"Türkiye'deki en büyük Özel Çevre Koruma Bölgesi hangisidir?",opts:['Köyceğiz-Dalyan','Göksu Deltası','Gediz Deltası','Belek'],ans:0,type:'🇹🇷 Uzman'},{img:'https://picsum.photos/seed/footprint1/480/160',q:'Ekolojik ayak izi hesaplamasında en büyük pay kime aittir?',opts:['Su tüketimi','Karbon emisyonu','Arazi kullanımı','Madencilik'],ans:1,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/megadiversity/480/160',q:'Türkiye neden "megabiyoçeşitlilik" ülkesi sayılır?',opts:['Üç iklim bölgesi ve iki kıta geçiş noktası','Sahil uzunluğu','Nüfus yoğunluğu','Ekonomik büyüklük'],ans:0,type:'🇹🇷 Uzman'},{img:'https://picsum.photos/seed/invasive1/480/160',q:'İstilacı tür ekosistemlere nasıl zarar verir?',opts:['Yerli türlerle rekabet ederek biyoçeşitliği düşürür','Toprağı güçlendirir','Besin döngüsünü hızlandırır','Diğer türleri besler'],ans:0,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/trophic/480/160',q:'Trofik basamak (trophic level) ne ifade eder?',opts:['Gıda zincirindeki enerji aktarım kademesi','Bir türün nüfusu','Habitat büyüklüğü','Üreme hızı'],ans:0,type:'🔬 Bilim'}]}};
const BASE={kolay:30,orta:45,zor:65};
const D_LABEL={kolay:'Kolay',orta:'Orta',zor:'Zor'};
const D_CLASS={kolay:'easy',orta:'medium',zor:'hard'};
let selCat='Kuşlar',selDiff='kolay',selIcon='🦅',curQ=0,roundDP=0,streak=0,timer=null,timeLeft=15,answered=false,totalDP=1840,activeQs=[];
function nav(id){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.querySelectorAll('.sib').forEach(s=>s.classList.remove('active'));document.getElementById('page-'+id).classList.add('active');const s=document.getElementById('sib-'+id);if(s)s.classList.add('active');}
function selectCat(cat,icon){selCat=cat;selIcon=icon;document.getElementById('ds-icon').textContent=icon;document.getElementById('ds-name').textContent=cat;const db=document.getElementById('diff-box');db.style.display='block';setTimeout(()=>db.scrollIntoView({behavior:'smooth',block:'nearest'}),50);nav('catsel');}
function startQuiz(diff){selDiff=diff;activeQs=[...QS[selCat][diff]].sort(()=>Math.random()-.5);curQ=0;roundDP=0;streak=0;answered=false;document.getElementById('d-pill').textContent=D_LABEL[diff];document.getElementById('d-pill').className='d-pill '+D_CLASS[diff];document.getElementById('quiz-cat-pill').textContent=selIcon+' '+selCat;document.getElementById('live-dp').textContent=0;nav('quiz');renderQ();}
function renderQ(){const q=activeQs[curQ%activeQs.length];answered=false;document.getElementById('q-badge').textContent=q.type;document.getElementById('q-text').textContent=q.q;document.getElementById('live-dp').textContent=roundDP;document.getElementById('dp-award').classList.remove('show');document.getElementById('next-btn').classList.remove('show');const img=document.getElementById('q-img'),ph=document.getElementById('q-ph');img.style.display='none';ph.style.display='flex';ph.textContent=selIcon;img.onload=()=>{img.style.display='block';ph.style.display='none';};img.onerror=()=>{img.style.display='none';ph.style.display='flex';};img.src=q.img;const sb=document.getElementById('streak-bar');if(streak>=2){sb.style.display='flex';document.getElementById('streak-txt').textContent=streak+'× Seri! Kombo aktif';}else{sb.style.display='none';}const dots=document.getElementById('q-dots');dots.innerHTML='';const tot=Math.min(activeQs.length,5);for(let i=0;i<tot;i++){const d=document.createElement('div');d.className='q-dot'+(i<curQ?' done':i===curQ?' cur':'');dots.appendChild(d);}const grid=document.getElementById('opts');grid.innerHTML='';['A','B','C','D'].forEach((l,i)=>{const b=document.createElement('button');b.className='opt';b.innerHTML=`<span class="opt-ltr">${l}</span>${q.opts[i]}`;b.onclick=()=>pick(i,q.ans,BASE[selDiff]);grid.appendChild(b);});startTimer();}
function startTimer(){clearInterval(timer);timeLeft=15;const c=document.getElementById('t-circle'),n=document.getElementById('t-num');c.style.strokeDashoffset=0;c.style.stroke='#8dc98a';n.textContent=15;timer=setInterval(()=>{timeLeft--;n.textContent=timeLeft;c.style.strokeDashoffset=(1-timeLeft/15)*120;if(timeLeft<=5)c.style.stroke='#e05c3a';if(timeLeft<=0){clearInterval(timer);timeUp();}},1000);}
function timeUp(){if(answered)return;answered=true;clearInterval(timer);streak=0;const bs=document.querySelectorAll('.opt');bs[activeQs[curQ%activeQs.length].ans].classList.add('correct');bs.forEach(b=>b.disabled=true);showAward(0,'Süre doldu!','');document.getElementById('next-btn').classList.add('show');}
function pick(chosen,correct,base){if(answered)return;answered=true;clearInterval(timer);const bs=document.querySelectorAll('.opt');bs.forEach(b=>b.disabled=true);const spd=Math.max(1,+(1+(timeLeft/15)*.5).toFixed(2));if(chosen===correct){bs[chosen].classList.add('correct');streak++;const sb=streak>=3?1.3:streak>=2?1.15:1;const earn=Math.round(base*spd*sb);roundDP+=earn;totalDP+=earn;document.getElementById('live-dp').textContent=roundDP;document.getElementById('dp-display').textContent=totalDP.toLocaleString('tr-TR');document.getElementById('stat-dp').textContent=totalDP.toLocaleString('tr-TR');document.getElementById('my-sc').textContent=totalDP.toLocaleString('tr-TR');updateMilestone();showAward(earn,`Doğru! Hız ×${spd} · Seri ×${sb.toFixed(2)}`,`${base} × ${spd} × ${sb.toFixed(2)} = ${earn} DP`);}else{bs[chosen].classList.add('wrong');bs[correct].classList.add('correct');streak=0;showAward(0,'Yanlış. Doğru cevap işaretlendi.','');}document.getElementById('next-btn').classList.add('show');}
function showAward(pts,txt,form){const el=document.getElementById('dp-award');document.getElementById('award-pts').textContent=pts>0?`+${pts} DP`:'0 DP';document.getElementById('award-txt').textContent=txt;document.getElementById('award-form').textContent=form;el.classList.add('show');}
function nextQ(){curQ++;if(curQ>=Math.min(activeQs.length,5)){notify('🎉 Tur bitti! +'+roundDP+' DP kazandın!');setTimeout(()=>nav('home'),1400);return;}renderQ();}
function updateMilestone(){const pct=Math.min(100,Math.round((totalDP/2500)*100));document.getElementById('ml-fill').style.width=pct+'%';const left=Math.max(0,2500-totalDP);document.getElementById('ml-sub').textContent=totalDP.toLocaleString('tr-TR')+' / 2.500 DP — '+left+' DP daha gerekiyor';}
function notify(msg){const n=document.getElementById('notif');n.textContent=msg;n.classList.add('show');setTimeout(()=>n.classList.remove('show'),2600);}
</script>
