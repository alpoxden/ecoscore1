const QS={Kuşlar:{kolay:[{img:'https://picsum.photos/seed/eagle1/480/160',q:'Kartallar ve şahinler hangi kuş grubuna girer?',opts:['Yırtıcı Kuşlar','Su Kuşları','Ötücüler','Koşucular'],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/hummingbird/480/160',q:'Hangi kuş havada yerinde durarak uçabilir?',opts:['Sinekkuşu','Guguk Kuşu','Serçe','İbibik'],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/flamingo1/480/160',q:'Flamingolar neden pembe renktedir?',opts:['Doğuştan böyle doğar','Yedikleri yosun ve karides','Güneş etkisi','Su rengi'],ans:1,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/owl22/480/160',q:'Hangi kuş gece görüşüyle ünlüdür?',opts:['Baykuş','Kartal','Papağan','Leylek'],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/stork1/480/160',q:'Leylek kışları nereye göç eder?',opts:['Kuzey Avrupa','Güney ve Orta Afrika','Orta Asya','Avustralya'],ans:1,type:'🗺️ Göç'}],orta:[{img:'https://picsum.photos/seed/raptor2/480/160',q:'Bir yırtıcı kuşun dalış hızı yaklaşık kaç km/s olabilir?',opts:['80 km/s','150 km/s','300 km/s','500 km/s'],ans:2,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/bird_nest/480/160',q:"Türkiye'de hangi kuş nesli tehlike altındadır?",opts:['Kara Leylek','Güvercin','Bıldırcın','Saksağan'],ans:0,type:'🇹🇷 Türkiye'},{img:'https://picsum.photos/seed/bird_fly/480/160',q:'Kuşların yön bulmasında hangi mekanizma rol oynar?',opts:['Yalnızca koku','Manyetik alan ve yıldız konumu','Yalnızca güneş','Rüzgar yönü'],ans:1,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/pelican1/480/160',q:"Tepeli pelikan Türkiye'de en çok nerede ürer?",opts:['Karadeniz','Gediz Deltası','İç Anadolu','Doğu Anadolu'],ans:1,type:'🇹🇷 Türkiye'},{img:'https://picsum.photos/seed/migration/480/160',q:'Hangi kuş en uzun göç rotasına sahiptir?',opts:['Güvercin','Kutup Martısı','Leylek','Kırlangıç'],ans:1,type:'🗺️ Göç'}],zor:[{img:'https://picsum.photos/seed/eagle_rare/480/160',q:"Türkiye'nin hangi bölgesi en fazla yırtıcı kuş çeşidine ev sahipliği yapar?",opts:['Trakya','Karadeniz','Doğu Anadolu','Ege'],ans:2,type:'🇹🇷 Uzman'},{img:'https://picsum.photos/seed/bird_rare1/480/160',q:"Hangi kuş türü Türkiye'de yalnızca Gediz Deltası'nda ürer?",opts:['Küçük Flamingo','Tepeli Pelikan','Ak Pelikan','Bataklık Kırlangıcı'],ans:1,type:'🇹🇷 Uzman'},{img:'https://picsum.photos/seed/bird_adapt/480/160',q:"Bir şahinin dalış hızı kaç km/s'e ulaşabilir?",opts:['180','250','320','390'],ans:2,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/feather1/480/160',q:'Kuş tüylerindeki "barbül" ne işe yarar?',opts:['Renk verir','Tüyleri kilitler','Isı yalıtımı','Su iter'],ans:1,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/bird_song/480/160',q:'Kuşların şarkı söylemesi öncelikle ne için gelişmiştir?',opts:['İletişim kurmak','Bölge işaretlemek ve eş çekmek','Avlanmak','Uyarı vermek'],ans:1,type:'🔬 Bilim'}]},Memeliler:{kolay:[{img:'https://picsum.photos/seed/bat1/480/160',q:'Hangi memeli gerçek anlamda uçabilir?',opts:['Yarasa','Uçan Sincap','Sugar Glider','Colugo'],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/elephant1/480/160',q:'Filler kaç ay hamile kalır?',opts:['9 ay','14 ay','22 ay','3 yıl'],ans:2,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/hippo1/480/160',q:'Hangi memeli hem karada hem suda yaşayabilir?',opts:['Su Aygırı','Kurt','Fil','Zebra'],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/wolf1/480/160',q:"Türkiye'de hangi büyük yırtıcı memeli yaşamaktadır?",opts:['Asya Aslanı','Kurt ve Çakal','Kaplan','Leopar'],ans:1,type:'🇹🇷 Türkiye'},{img:'https://picsum.photos/seed/mammal1/480/160',q:'Yarasalar yön bulmak için ne kullanır?',opts:['Manyetik Alan','Ekolokasyon','Görme','Koku'],ans:1,type:'🧠 Bilgi'}],orta:[{img:'https://picsum.photos/seed/seal_med/480/160',q:"Akdeniz foku Türkiye'de en çok nerede görülür?",opts:['Karadeniz','Marmara','Ege ve Akdeniz mağaraları','Boğaz'],ans:2,type:'🇹🇷 Türkiye'},{img:'https://picsum.photos/seed/lynx1/480/160',q:"Hangisi Türkiye'ye özgü bir memeli alt türüdür?",opts:['Anadolu Vaşağı','Orman Faresi','Hamster','Kurt'],ans:0,type:'🇹🇷 Türkiye'},{img:'https://picsum.photos/seed/wolf_pack/480/160',q:'Bir kurt sürüsü ortalama kaç bireyden oluşur?',opts:['2-3','5-10','15-20','30+'],ans:1,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/bear1/480/160',q:"Türkiye'de boz ayı hangi bölgelerde yaşar?",opts:['Karadeniz ve Doğu Anadolu dağları','Ege kıyıları','Akdeniz sahili','İç Anadolu ovası'],ans:0,type:'🇹🇷 Türkiye'},{img:'https://picsum.photos/seed/mammal_track/480/160',q:'Hangi memelinin kalp-damar sistemi en güçlüdür?',opts:['Fil','Zürafa','Balina','Çita'],ans:1,type:'🔬 Bilim'}],zor:[{img:'https://picsum.photos/seed/rare_mammal/480/160',q:'Akdeniz foku dünyada kaç bireyden oluşan bir popülasyona sahiptir?',opts:['~100','~700','~3.000','~10.000'],ans:1,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/wolf_terr/480/160',q:'Bir kurt ailesinin bölgesi kaç km² olabilir?',opts:['10','50','200','600'],ans:2,type:'🔬 Bilim'},{img:'https://picsum.photos/seed/mammal_eco/480/160',q:"Türkiye'de \"Önemli Memeli Alanı\" statüsünde kaç bölge var?",opts:['5','12','25','40'],ans:2,type:'🇹🇷 Uzman'},{img:'https://picsum.photos/seed/dolphin_tr/480/160',q:"Türkiye denizlerinde hangi yunus türü en sık görülür?",opts:['Şişe Burunlu Yunus','Adi Yunus','Gri Yunus','Şeritli Yunus'],ans:1,type:'🇹🇷 Uzman'},{img:'https://picsum.photos/seed/bear_adapt/480/160',q:'Hibernasyon sırasında ayıların vücut sıcaklığı ne kadar düşer?',opts:['1-5°C','10-15°C','20-25°C','Hiç düşmez'],ans:0,type:'🔬 Bilim'}]},Flora:{kolay:[{img:'https://picsum.photos/seed/flower1/480/160',q:'Fotosentez nedir?',opts:["Bitkilerin güneşten besin üretmesi","Bitkilerin nefes alması","Tohumun çimlenmesi","Köklerin su emişi"],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/pine1/480/160',q:'Hangi ağaç kışın yapraklarını dökmez?',opts:['Çam','Meşe','Kavak','Kiraz'],ans:0,type:'🧠 Bilgi'},{img:'https://picsum.photos/seed/tulip1/480/160',q:"Türkiye'nin simgesi olan hangi çiçek Anadolu kökenlidir?",opts:['Lale','Gül','P